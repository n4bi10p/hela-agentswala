# Development Environment Variables
# Copy from .env.example and fill in your actual keys

NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_HELA_RPC_URL=https://testnet-rpc.helachain.com
NEXT_PUBLIC_HELA_EXPLORER_URL=https://testnet-explorer.helachain.com

# Contract Addresses - Update with deployed contract addresses
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000001
NEXT_PUBLIC_AGENT_ESCROW_ADDRESS=0x0000000000000000000000000000000000000002
NEXT_PUBLIC_AGENT_EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000003
NEXT_PUBLIC_HLUSD_TOKEN_ADDRESS=0x0000000000000000000000000000000000000004
